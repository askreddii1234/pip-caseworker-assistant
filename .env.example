# Copy to .env and fill in. Do NOT commit .env.

# --- AI ---
# Optional. If unset, the app runs in deterministic mock mode.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Deployment ---
# The hostname or IP that the browser will use to reach the app.
# Local dev:    PUBLIC_HOST=localhost
# GCP VM demo:  PUBLIC_HOST=<vm-external-ip>
# Domain:       PUBLIC_HOST=demo.example.com
PUBLIC_HOST=localhost

# CORS allow-list for the FastAPI backend. Comma-separated origins.
# Must include the URL the browser uses to load the frontend.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000
